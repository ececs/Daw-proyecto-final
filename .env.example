# ============================================================
# D4-Ticket AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database & Cache ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ticketai
REDIS_URL=redis://redis:6379

# --- Auth ---
SECRET_KEY=your-super-secret-key-min-32-chars-replace-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Storage (MinIO local / Cloudflare R2 in prod) ---
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=attachments
STORAGE_REGION=us-east-1

# --- AI ---
# Provider: "google" (default), "anthropic" or "openai"
AI_PROVIDER=google
AI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your-google-ai-studio-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Optional access control / demo ---
ALLOWED_EMAILS=*
DEMO_ACCESS_CODE=

# --- Next.js (prefix NEXT_PUBLIC_ for client-side) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
