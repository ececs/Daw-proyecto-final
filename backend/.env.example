# ─── Database ─────────────────────────────────────────────────────────────────
# asyncpg driver — use postgresql+asyncpg:// (never the sync postgres:// form)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ticketai

# ─── Authentication (JWT) ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── File Storage (S3-compatible) ─────────────────────────────────────────────
# Local dev: MinIO (docker-compose). Production: Cloudflare R2 (same API).
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=attachments
STORAGE_REGION=us-east-1

# ─── AI Agent ─────────────────────────────────────────────────────────────────
# AI_PROVIDER: "google" (Gemini, free tier 500 req/day) | "anthropic" (Claude)
AI_PROVIDER=google
AI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ─── AI Agent Memory (LangGraph PostgresSaver) ────────────────────────────────
# Conversation memory is persisted in PostgreSQL automatically using the same
# DATABASE_URL above. The checkpointer creates checkpoint_* tables on first start.
# No extra configuration needed — it initializes at startup and degrades
# gracefully to stateless mode if the DB is unreachable.

# ─── Observability — LangSmith ────────────────────────────────────────────────
# Traces every LLM call, tool invocation, latency, and token cost.
# Get your API key at https://smith.langchain.com
# Set LANGSMITH_TRACING=true to enable (safe to leave false in dev).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=d4-ticket-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── Redis Cache ──────────────────────────────────────────────────────────────
# Optional: set to enable 60s caching on GET /tickets (invalidated on write).
# Leave empty to run without cache — the endpoint degrades gracefully.
# Local dev: redis://localhost:6379. Production: Railway Redis add-on URL.
REDIS_URL=
